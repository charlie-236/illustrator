generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Generation {
  id               String   @id @default(cuid())
  filePath         String
  promptPos        String
  promptNeg        String
  model            String
  lora             String?                  // human-readable summary, e.g. "name (1.00), name2 (0.80)"
  lorasJson        Json?                    // structured: [{name: string, weight: number}, ...] or null
  assembledPos     String?                  // final positive prompt sent to ComfyUI (defaults + triggers + user); null for legacy records
  assembledNeg     String?                  // final negative prompt sent to ComfyUI; null for legacy records
  seed             BigInt
  cfg              Float
  steps            Int
  width            Int
  height           Int
  sampler          String   @default("euler")
  scheduler        String   @default("normal")
  highResFix       Boolean  @default(false)
  isFavorite       Boolean  @default(false)
  mediaType        String   @default("image")  // "image" | "video"
  frames           Int?                         // null for images; frame count for videos
  fps              Int?                         // null for images; frame rate for videos
  projectId        String?
  project          Project? @relation("ProjectClips", fields: [projectId], references: [id], onDelete: SetNull)
  position         Int?                         // null for non-project generations; sort order within a project
  isStitched       Boolean  @default(false)     // true for stitched-export gallery entries
  parentProjectId  String?                      // source project for stitched outputs
  parentProject    Project? @relation("StitchedFromProject", fields: [parentProjectId], references: [id], onDelete: SetNull)
  stitchedClipIds  String?                      // JSON array of source generation IDs
  videoLorasJson   Json?                        // WanLoraSpec[] for video; null for image and legacy
  lightning        Boolean?                     // true for Wan 2.2 Lightning; null for image and legacy
  sceneId          String?                      // soft ref to StoryboardScene.id within a Storyboard row's scenesJson; null for non-storyboard clips
  storyboardId     String?                      // soft ref to Storyboard.id; set on stitched outputs created from a storyboard's canonicals
  createdAt        DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([projectId])
}

model Project {
  id              String       @id @default(cuid())
  name            String
  description     String?
  styleNote       String?
  defaultFrames   Int?
  defaultSteps    Int?
  defaultCfg      Float?
  defaultWidth    Int?
  defaultHeight   Int?
  defaultLightning  Boolean?
  defaultVideoLoras String?      // JSON-encoded WanLoraSpec[]
  defaultCheckpoint String?      // image checkpoint name used for keyframe generation
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  generations       Generation[] @relation("ProjectClips")
  stitchedExports   Generation[] @relation("StitchedFromProject")
  storyboards       Storyboard[]
}

model Storyboard {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String   @default("Untitled storyboard")
  scenesJson    Json                              // StoryboardScene[]
  storyIdea     String
  generatedAt   DateTime
  quickGenerate Boolean  @default(false)
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId, position])
}

model CheckpointConfig {
  id                    String   @id @default(cuid())
  checkpointName        String   @unique
  friendlyName          String   @default("")
  baseModel             String   @default("")
  category              String?
  defaultWidth          Int?
  defaultHeight         Int?
  defaultPositivePrompt String   @default("")
  defaultNegativePrompt String   @default("")
  description           String?
  url                   String?
  updatedAt             DateTime @updatedAt
  // Per-checkpoint generation defaults (all nullable; null = no default, leave form alone)
  defaultSteps          Int?
  defaultCfg            Float?
  defaultSampler        String?
  defaultScheduler      String?
  defaultHrf            Boolean?
}

model LoraConfig {
  id            String   @id @default(cuid())
  loraName      String   @unique
  friendlyName  String   @default("")
  triggerWords  String   @default("")
  baseModel     String   @default("")
  category      String?
  description   String?
  url           String?
  updatedAt     DateTime @updatedAt
  appliesToHigh Boolean  @default(true)
  appliesToLow  Boolean  @default(true)
}

model EmbeddingConfig {
  id            String   @id @default(cuid())
  embeddingName String   @unique
  friendlyName  String   @default("")
  triggerWords  String   @default("")
  baseModel     String   @default("")
  category      String?
  description   String?
  url           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model QueuedJob {
  id              String    @id @default(cuid())

  // What media type and full payload — enough to re-submit to ComfyUI
  mediaType       String    // 'image' | 'video' | 'stitch'
  payloadJson     Json      // GenerationParams | VideoRequest | StitchParams (full request body)

  // Lineage — tie back to whatever surface created this
  generationId    String?   // populated by runner on submission (video/stitch pre-set; image set on finalize)
  projectId       String?   // for project-context jobs
  sceneId         String?   // for storyboard scenes
  storyboardId    String?   // for storyboard batches

  // Lifecycle state machine
  status          String    @default("pending")
  // 'pending'   — in DB, not yet submitted to ComfyUI
  // 'submitted' — POSTed to ComfyUI, awaiting execution_start
  // 'running'   — ComfyUI accepted, executing or queued internally
  // 'complete'  — finalized successfully
  // 'failed'    — terminal failure
  // 'cancelled' — user-cancelled (pre or during)

  promptId        String?   // ComfyUI prompt_id, populated after submission

  // Retry tracking (auto-retry on VM loss only)
  retryCount      Int       @default(0)
  lastFailReason  String?   // 'vm_lost' | 'workflow_error' | 'aborted' | 'timeout'

  // Ordering (FIFO by position+createdAt; position reserved for future reorder UI)
  position        Int       @default(0)

  // Timestamps
  createdAt       DateTime  @default(now())
  submittedAt     DateTime?
  startedAt       DateTime? // when ComfyUI's execution_start event arrived
  finishedAt      DateTime?

  @@index([status, position])
  @@index([promptId])
}

model SamplingPreset {
  id          String   @id @default(cuid())
  name        String   @unique
  paramsJson  Json     // SamplingParams shape
  isBuiltIn   Boolean  @default(false)  // seeded presets cannot be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  chats       Chat[]
}

model Chat {
  id                   String          @id @default(cuid())
  name                 String          @default("Untitled chat")
  systemPromptOverride String?         // null = use the canonical director-mode prompt
  samplingPresetId     String?
  samplingPreset       SamplingPreset? @relation(fields: [samplingPresetId], references: [id], onDelete: SetNull)
  samplingOverridesJson Json?          // Partial<SamplingParams>
  contextLimit         Int             @default(64000)
  activeBranchesJson   Json?           // Record<parentMessageId, activeBranchIndex>; null = all branches at index 0
  suggestionsEnabled   Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  messages             Message[]

  @@index([updatedAt])
}

model Message {
  id              String   @id @default(cuid())
  chatId          String
  chat            Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role            String   // 'user' | 'assistant' | 'system'
  content         String   @db.Text  // raw including <think> tags
  parentMessageId String?  // null for first message; otherwise the message this one replies to / branches from
  branchIndex     Int      @default(0)  // 0 = primary; 1+ = alternate branches at this parent (7b)
  suggestionsJson Json?    // Suggestion[] | null — cached next-prompt suggestions for assistant messages
  createdAt       DateTime @default(now())

  parent          Message?  @relation("MessageBranches", fields: [parentMessageId], references: [id], onDelete: SetNull)
  branches        Message[] @relation("MessageBranches")

  @@index([chatId, createdAt])
  @@index([parentMessageId, branchIndex])
}
