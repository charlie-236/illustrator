# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string. Required — app fails to start without it.
DATABASE_URL="postgresql://postgres:password@localhost:5432/illustrator"

# ── Output directories ────────────────────────────────────────────────────────
# All three directories must exist and be writable before starting the app.
# They may all point to the same path if you don't want them split, but the
# capability to separate them exists. Files are served via /api/images/<filename>
# regardless of which directory they live in — the serve route searches all three.
#
# Migration note: if you change VIDEO_OUTPUT_DIR or STITCH_OUTPUT_DIR to a new
# path after you already have files, manually move existing .webm and stitched
# .mp4 files to the new locations or they will 404 in the gallery.

# Absolute path on mint-pc where PNG outputs from image generation are written.
# Must exist and be writable. App throws on image generation if unset.
IMAGE_OUTPUT_DIR=~./illustrator-output/images

# Absolute path where raw video clips (.webm) from Wan 2.2 generation land.
# Must exist and be writable. May be the same as IMAGE_OUTPUT_DIR.
# App returns 500 on video generation if unset.
VIDEO_OUTPUT_DIR=~./illustrator-output/clips

# Absolute path where project stitch outputs (.mp4) land.
# Must exist and be writable. May overlap with VIDEO_OUTPUT_DIR if desired.
# App returns 500 on stitch start if unset.
STITCH_OUTPUT_DIR=~./illustrator-output/videos

# ── Gallery ───────────────────────────────────────────────────────────────────

# Number of items per page for gallery infinite-scroll pagination.
# Default 30 if unset. Server-side cap of 100 regardless of this value.
GALLERY_PAGE_SIZE=30

# ── ComfyUI ───────────────────────────────────────────────────────────────────

# ComfyUI HTTP endpoint. Reached via SSH tunnel on localhost.
# Used for image/video generation, file fetch (/view), embeddings list,
# /interrupt, and queue management. Defaults to http://127.0.0.1:8188 if unset.
COMFYUI_URL=http://127.0.0.1:8188

# ComfyUI WebSocket endpoint. Reached via SSH tunnel on localhost.
# Used for streaming generation progress and binary image frames.
# Defaults to ws://127.0.0.1:8188 if unset.
COMFYUI_WS_URL=ws://127.0.0.1:8188

# ── A100 VM SSH credentials ───────────────────────────────────────────────────
# All three are required for any SSH-using route (model ingest, model delete,
# video SSH cleanup). Routes return 500 if any of these are missing.

# SSH username for the Azure VM.
A100_VM_USER=username

# Tailscale IP of the Azure VM. Never contact this directly from Next.js —
# use the localhost SSH tunnels instead. This is only used for SSH commands.
A100_VM_IP=xxx.xxx.xxx.xxx

# Absolute path to the private key used to SSH into the A100 VM.
A100_SSH_KEY_PATH=path-to-models-vm

# ── ComfyUI VM paths ──────────────────────────────────────────────────────────

# Root directory of ComfyUI's model files on the VM.
# Used to construct checkpoint/LoRA/embedding remote paths for ingest and delete.
# Defaults to /models/ComfyUI/models if unset (standard ComfyUI install location).
COMFYUI_MODELS_ROOT=/models/ComfyUI/models

# ComfyUI's output directory on the VM.
# Used for the SSH cleanup glob that removes orphan video files after generation
# completion or abort. Defaults to /models/ComfyUI/output if unset.
COMFYUI_OUTPUT_PATH=/models/ComfyUI/output

# ── CivitAI ───────────────────────────────────────────────────────────────────

# CivitAI API token. Get from civitai.com → Account Settings → API Keys.
# Used by add_model.sh and /api/models/ingest to download model files.
# Routes return 500 if unset; the Polish flow is unaffected.
CIVITAI_TOKEN="paste-token-from-civitai-account-settings"

# ── LLM / Prompt Polish ───────────────────────────────────────────────────────

# OpenAI-compatible chat-completions endpoint for prompt polish.
# Reached via SSH tunnel on localhost (llama-server or compatible).
# Required when the Polish button is used; returns 200 with polished:false
# (graceful degradation) if unset or unreachable.
LLM_ENDPOINT=http://127.0.0.1:11438/v1/chat/completions

# Model identifier passed to the LLM as the `model` field.
# For llama-server this is typically the .gguf file path.
# Missing value means polish requests fail silently with reason: llm_error.
POLISH_LLM_MODEL=/path/to/your/model.gguf

# Polish call timeout in milliseconds. Default 30000 (30 seconds).
# If the LLM takes longer the client gets polished:false / reason:timeout.
POLISH_TIMEOUT_MS=30000

# Polish LLM sampling parameters. Defaults match values tuned during development.
# temperature: lower = more deterministic. top_p: nucleus sampling threshold.
# repeat_penalty: discourages token repetition. max_tokens: response length cap.
POLISH_TEMPERATURE=0.15
POLISH_TOP_P=0.9
POLISH_REPEAT_PENALTY=1.05
POLISH_MAX_TOKENS=600

# ── LLM / Storyboard Generation ───────────────────────────────────────────────
# Storyboards reuse LLM_ENDPOINT above (same OpenAI-compatible tunnel).
# Model and sampling are separate from polish so they can be tuned independently.

# Model identifier passed to the LLM as the `model` field for storyboard requests.
# Can match POLISH_LLM_MODEL or differ (different .gguf for creative writing vs prompt expansion).
# Missing means storyboard requests fail with reason: llm_error (graceful degradation).
STORYBOARD_LLM_MODEL=/path/to/your/model.gguf

# Storyboard call timeout in milliseconds. Default 60000 (60 seconds).
# Storyboards are 5+ scenes of structured creative output — longer than polish.
STORYBOARD_TIMEOUT_MS=60000

# Sampling params for storyboard generation. Higher temperature than polish for
# creative output, but capped to keep the structured format stable.
STORYBOARD_TEMPERATURE=0.7
STORYBOARD_TOP_P=0.9
STORYBOARD_MAX_TOKENS=3000

# ── Job watchdog timeouts ─────────────────────────────────────────────────────
# A job sitting longer than its timeout is force-aborted with an error event.
# Defaults match the historical hardcoded values. Use 0 to hit the default.

# Image generation watchdog. Default 600000 (10 minutes).
IMAGE_JOB_TIMEOUT_MS=600000

# Video generation watchdog. Default 900000 (15 minutes).
# Wan 2.2 at 1280x704 takes ~5 min on A100; 15 min gives headroom.
VIDEO_JOB_TIMEOUT_MS=900000

# Project stitch watchdog. Default 300000 (5 minutes).
# ffmpeg runs locally on mint-pc and is fast; 5 min is generous.
STITCH_JOB_TIMEOUT_MS=300000

# How long a completed job stays queryable via /api/jobs/active.
# Default 300000 (5 minutes) — long enough to reattach the queue tray after
# a normal page reload without cluttering the list for long sessions.
RECENT_COMPLETED_TTL_MS=300000

# ── Queue polling ─────────────────────────────────────────────────────────────

# How often (ms) the queue tray polls /api/jobs/active while jobs are active.
# Must use the NEXT_PUBLIC_ prefix so the client-side QueueContext can read it.
# Default 5000 (5 seconds). Lower = more responsive; higher = less server load.
NEXT_PUBLIC_QUEUE_POLL_INTERVAL_MS=5000
